{% extends 'email/base.html.twig' %}
{% block content %}
<h2>Bienvenue, {{ member.firstName }} !</h2>
<p>Votre inscription à {{ library_name }} a bien été enregistrée.</p>
<p><strong>Votre numéro d'adhérent :</strong> {{ member.memberNumber }}</p>
<p><strong>Email :</strong> {{ member.email }}</p>
<p><strong>Adhésion valable jusqu'au :</strong> {{ member.membershipExpiry|date('d/m/Y') }}</p>
<p>Vous pouvez maintenant emprunter jusqu'à {{ member.maxLoans }} ouvrages simultanément.</p>
{% endblock %}
